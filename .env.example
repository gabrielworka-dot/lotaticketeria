JWT_SECRET=lota_ticketeria_segredo_2025
PORT=3000

# Pasta de dados persistente (Volume no Railway montado em /data)
DATA_DIR=/data

# Mercado Pago — conta ÚNICA da plataforma (todo pagamento cai aqui)
# Access Token: mercadopago.com.br/developers/panel/app > Credenciais de produção
# Public Key: mesma tela, é a chave segura pra expor no navegador (checkout transparente)
MP_ACCESS_TOKEN=APP_USR-SEU_TOKEN_AQUI
MP_PUBLIC_KEY=APP_USR-SUA_PUBLIC_KEY_AQUI
MP_MARKETPLACE_FEE_PERCENT=10

# Resend — e-mail de confirmação de cadastro, ingressos e recuperação de senha
RESEND_API_KEY=re_SUA_CHAVE_AQUI
RESEND_FROM_EMAIL=Lota Ticketeria <onboarding@resend.dev>

# Recuperação de emergência do admin — use uma string longa e aleatória só sua.
# Serve pra trocar e-mail/senha do admin sem depender de e-mail (veja instruções do assistente).
ADMIN_RECOVERY_SECRET=defina_uma_chave_bem_dificil_de_adivinhar_aqui

# Asaas — provedor de pagamento alternativo (checkout hospedado)
# Chave: painel do Asaas > Integrações > Chaves de API
ASAAS_API_KEY=SUA_CHAVE_AQUI
ASAAS_SANDBOX=true
